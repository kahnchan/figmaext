{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["@figma/plugin-typings"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@ui/*": ["src/ui/*"],
      "@plugin/*": ["src/plugin/*"]
    }
  },
  "include": ["src"]
}
